# 管理端 Vite：开发环境默认走代理，将 /api 转发到后端（见仓库根目录 vite.config.management.ts）
# 一般无需配置即可联调 localhost:3000
# 联调自检：npm run check:management-api

# 须与后端 backend/.env 中 API_KEY 完全一致（默认 default-api-key）
# VITE_API_KEY=default-api-key

# 须与后端 MANAGEMENT_JWT_ROLES 一致（逗号分隔；不设时前后端各有默认）
# VITE_MANAGEMENT_JWT_ROLES=ADMIN,USER

# 生产构建：API 与页面不同域时设为后端 API 根（可含 /api 后缀）；开发环境 HTTP 仍只用代理 /api，不受此项影响
# WebSocket 会从该 URL 解析主机，请勿填管理端 dev 端口（3001/3002）
# VITE_API_BASE_URL=https://api.example.com/api

# 登录页「返回官网」链接；不设时开发环境默认 http://localhost:5173（与主站 Vite 默认端口一致）
# VITE_PUBLIC_SITE_URL=https://www.example.com
